@startuml 04-deployment
title Flint Secure — Deployment Diagram

node "Oracle Cloud ARM64" {
  node "App VM" {
    artifact "flint-api\n(Go binary)" as API
    artifact "redis-persist :6379" as R1
    artifact "redis-cache :6380" as R2
    artifact "nats-jetstream" as NATS
  }
}

node "Database Host" {
  database "PostgreSQL" as PG
}

node "PSP Data Center" {
  component "PSP Backend" as PSP
}

node "User Devices" {
  component "JS SDK" as JS
  component "Android SDK" as AND
  component "iOS SDK" as IOS
}

cloud "MaxMind" {
  component "GeoLite2 MMDB" as MMDB
}

API --> R1
API --> R2
API --> NATS
API --> MMDB : in-memory
API --> PG : async via workers
PSP --> API : REST
JS --> API
AND --> API
IOS --> API

@enduml
