@startuml 06-component
' UML 2.0 — Structure: Component Diagram
skinparam shadowing false
skinparam defaultFontSize 11
skinparam componentStyle rectangle

title Flint Secure — Component Diagram (Go API)

package "handlers" {
  component [IdentifyHandler] as IdentifyHandler
  component [ScoreHandler] as ScoreHandler
  component [AdminHandler] as AdminHandler
}

package "core" {
  component [matching] as matching
  component [scoring] as scoring
  component [velocity] as velocity
  component [geoip] as geoip
}

package "infrastructure" {
  component [store] as store
  component [middleware] as middleware
  component [messaging] as messaging
  component [quota] as quota
}

database "Redis" as Redis
database "PostgreSQL" as PG
queue "NATS" as NATS

IdentifyHandler --> matching
IdentifyHandler --> store
ScoreHandler --> scoring
ScoreHandler --> velocity
ScoreHandler --> store
ScoreHandler --> quota
ScoreHandler --> messaging
middleware --> IdentifyHandler
middleware --> ScoreHandler
store --> Redis
messaging --> NATS

note right of scoring
  Pure function —
  no I/O inside engine
end note

package "go_workers" {
  component [device_indexer] as device_indexer
  component [transaction_indexer] as transaction_indexer
  component [user_profile_builder] as user_profile_builder
  component [device_trust] as device_trust
  component [recipient_risk] as recipient_risk
}

device_indexer --> NATS
device_indexer --> PG

@enduml
