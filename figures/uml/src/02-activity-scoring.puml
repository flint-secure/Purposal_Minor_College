@startuml 02-activity-scoring
' UML 2.0 — Behavior: Activity Diagram
skinparam shadowing false
skinparam defaultFontSize 11

title Flint Secure — Activity Diagram (Risk Scoring)

start
:Fetch device, profile,\nvelocity from Redis;
:Compute identity risk\n(SIM swap binding);
if (Quota exceeded?) then (yes)
  :Return BLOCK;
  stop
endif
partition "scoring.Score() <<pure function>>" {
  :Compute 7 risk components;
  :Apply interaction terms;
  if (Hard floor triggered?) then (yes)
    :Escalate to BLOCK;
  else (no)
    :Sum weighted score 0-100;
  endif
}
if (score >= block_threshold?) then (yes)
  :Decision = BLOCK;
elseif (score >= flag_threshold?) then (yes)
  :Decision = FLAG;
else (no)
  :Decision = ALLOW;
endif
:Return JSON response;
:Async NATS + velocity write;
stop

@enduml
