@startuml 01-use-case
' UML 2.0: actors outside system boundary; left-to-right layout (actors left, system right)
' Ref: plantuml.com/use-case-diagram, uml-diagrams.org/use-case-reference.html
left to right direction
skinparam shadowing false
skinparam nodesep 70
skinparam ranksep 35
skinparam defaultFontSize 13
skinparam actorStyle stickman
skinparam rectangle {
  BorderColor #333333
  BackgroundColor #FAFAFA
}

actor "PSP Backend" as PSP
actor "Web SDK" as SDK
actor "Fraud Analyst" as FA

rectangle "Flint Secure" <<system>> {
  (Identify Device) as UC1
  (Score Transaction) as UC2
  (Review Alerts) as UC3
}

PSP --> UC1
PSP --> UC2
SDK --> UC1
SDK --> UC2
FA --> UC3

@enduml
